[flake8]
max-line-length = 127
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    venv,
    env,
    ENV,
    .eggs,
    *.egg,
    build,
    dist,
    .venv,
    models

ignore =
    # Whitespace before ':'
    E203,
    # Line too long (handled by black)
    E501,
    # Line break before binary operator
    W503,
    # Module imported but unused (for __init__.py files)
    F401

per-file-ignores =
    __init__.py:F401
    # Old files kept for backward compatibility
    predict.py:F401,E402
    foodnames.py:E501
